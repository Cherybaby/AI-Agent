# Optional: Feishu webhook override
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# Optional: Zhihu cookie (copy from browser); only needed to boost API/website success
ZHIHU_COOKIE=z_c0=...; d_c0=...; _xsrf=...

# Optional: cookie expiry time for reminder (ISO-8601)
ZHIHU_COOKIE_EXPIRES_AT=2026-07-01T01:00:00+08:00

# Optional: override website source pages
ZHIHU_HOT_URLS=https://www.zhihu.com/hot,https://www.zhihu.com/

# Optional: custom JSON fallback
ZHIHU_JSON_URL=
